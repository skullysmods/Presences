{
  "$schema": "https://schemas.premid.app/metadata/1.16",
  "apiVersion": 1,
  "author": {
    "name": "Jeazzzz",
    "id": "1259853916707749982"
  },
  "service": "AnimeHeaven",
  "altnames": [
    "Anime Heaven",
    "AnimeHeaven.Me"
  ],
  "description": {
    "en": "AnimeHeaven is a site for browsing anime schedules, tracking releases, and streaming anime episodes."
  },
  "url": "animeheaven.me",
  "regExp": "^https?[:][/][/]([a-z0-9-]+[.])*animeheaven[.]me([/]|$)",
  "version": "1.0.0",
  "logo": "https://i.imgur.com/Y65f6pt.png",
  "thumbnail": "https://i.imgur.com/WcseDVm.png",
  "color": "#dd0021",
  "category": "anime",
  "tags": [
    "anime",
    "streaming",
    "video",
    "schedule"
  ],
  "settings": [
    {
      "id": "showButtons",
      "title": "Show Buttons",
      "icon": "fas fa-link",
      "value": true,
      "description": "Show a button to the anime page while watching an episode"
    },
    {
      "id": "showBrowsingTimestamp",
      "title": "Show Browsing Time",
      "icon": "fas fa-stopwatch",
      "value": true,
      "description": "Show elapsed time while browsing AnimeHeaven"
    }
  ]
}
